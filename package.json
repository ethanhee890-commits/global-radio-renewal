{
  "name": "global-radio-renewal",
  "description": "지구라디오 리뉴얼을 위한 별도 모바일 PWA/하이브리드 앱",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:lan": "vite --host 0.0.0.0",
    "dev:api": "node server/naver-place-proxy.cjs",
    "dev:threads-api": "node server/threads-automation.cjs",
    "dev:with-api": "powershell -ExecutionPolicy Bypass -File ./start-dev.ps1",
    "dev:lan-with-api": "powershell -ExecutionPolicy Bypass -File ./start-dev.ps1 -Lan",
    "lint": "eslint . --max-warnings=0",
    "security:scan": "node scripts/security-scan.cjs",
    "assets:brand": "node scripts/generate-jiguradio-final-assets.cjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc --noEmit && vite build",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build && npm run security:scan",
    "mobile:sync": "npm run build && cap sync",
    "android:sync": "npm run build && cap sync android",
    "android:open": "cap open android",
    "android:debug": "powershell -ExecutionPolicy Bypass -File ./scripts/build-android.ps1 -Task assembleDebug",
    "android:bundle": "powershell -ExecutionPolicy Bypass -File ./scripts/build-android.ps1 -Task bundleRelease",
    "ios:sync": "npm run build && cap sync ios",
    "ios:open": "cap open ios"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/local-notifications": "^8.2.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.61.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.6",
    "vitest": "^4.1.10"
  }
}
